{
  "expo": {
    "name": "Huddle",
    "slug": "huddle",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "huddle",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.placeholder.huddle"
    },
    "android": {
      "package": "app.placeholder.huddle"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}

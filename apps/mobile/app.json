{
  "expo": {
    "name": "Huddle",
    "slug": "huddle",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "huddle",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.huddleapp.huddle"
    },
    "android": {
      "package": "com.huddleapp.huddle"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": ["expo-router", "expo-secure-store", "expo-web-browser", "expo-notifications"],
    "experiments": {
      "typedRoutes": true
    }
  }
}

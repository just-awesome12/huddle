# =====================================================================
# Huddle — environment variable template
# =====================================================================
# Copy this file to .env.local at the repo root (and into apps/web and
# apps/mobile as needed). NEVER commit a real .env.local. Values below
# are placeholders. Acquire real values per docs/SETUP.md.
# =====================================================================

# ---- Supabase (Phase 0) ----------------------------------------------
# From: https://supabase.com/dashboard/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service-role key. Used ONLY by Edge Functions and local migration
# scripts. NEVER ship to any client bundle, ever.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ---- Expo / Mobile (Phase 0) -----------------------------------------
# Public vars exposed to the mobile app must be prefixed EXPO_PUBLIC_.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ---- Cloudflare Turnstile (Phase 2 — placeholder for Phase 0) --------
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# ---- OAuth providers (Phase 2 — placeholder for Phase 0) -------------
# Configured in the Supabase dashboard, not as env vars on the client.
# Document any provider-specific dev URLs here for reference.
